# 이 파일을 .env로 복사해서 채운다. .env는 절대 커밋하지 않는다.
#   cp .env.example .env

# 서비스 도메인. VM의 공인 IP를 이 도메인의 A 레코드로 걸어 둬야 한다.
# ⚠️ IP를 그대로 넣으면 안 된다 — Let's Encrypt는 IP로 인증서를 발급하지 않는다.
#    도메인이 없으면 sslip.io를 쓸 것: 공인 IP가 1.2.3.4면 → 1-2-3-4.sslip.io
SITE_DOMAIN=example.com

# 공유 링크와 OG 태그의 절대경로 계산에 쓰인다. SITE_DOMAIN과 같은 곳을 가리켜야 한다.
# ⚠️ 빌드 시점에 번들에 박힌다. 바꾸면 `docker compose build web`을 다시 해야 한다.
NEXT_PUBLIC_SITE_URL=https://example.com

# Postgres 비밀번호. 외부에 열려 있진 않지만 짐작 가능한 값은 쓰지 말 것.
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# GET /api/admin/summary 를 여는 토큰. 이 프로젝트에서 수치를 볼 유일한 방법이다.
# 비워 두면 해당 엔드포인트는 404가 되어 아예 없는 것처럼 동작한다.
#   openssl rand -hex 32
ADMIN_TOKEN=
