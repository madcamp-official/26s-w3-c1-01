// Firestore 보안 규칙. **이 파일은 기록용이고, 실제 적용은 Firebase 콘솔에서 한다.**
// (콘솔 → Firestore Database → 규칙 → 붙여넣기 → 게시)
//
// 처음에는 콘솔이 만들어준 테스트 모드 규칙이 그대로 있었다:
//   match /{document=**} { allow read, write: if request.time < timestamp.date(2026, 8, 19); }
// 이건 만료 전까지 **누구에게나 전체 읽기/쓰기를 허용한다.** app/google-services.json이
// 공개 저장소에 있어 프로젝트 ID가 비밀이 아니므로, 앱을 설치하지 않은 사람도
// telemetry_feedback(사용자가 직접 쓴 자유 텍스트)까지 전부 긁어갈 수 있었다.
//
// 이 앱에는 로그인이 없다. 그래서 "쓰기만 허용, 읽기 전면 차단"이 유일하게
// 성립하는 모델이다. 데이터 확인은 관리자(콘솔/Admin SDK)로만 한다 —
// 관리자는 규칙을 우회하므로 팀이 통계를 보는 데는 지장이 없다.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 원본 이벤트와 사용자 피드백. 읽기·삭제는 막는다.
    //
    // **컬렉션마다 필드 구성이 다르다.** 처음에 둘 다 같은 검증(eventName 필수)을
    // 걸었다가 업로드가 통째로 막혔다 — toFeedbackMap()에는 eventName이 없는데,
    // batch는 원자적이라 피드백 하나가 거부되면 같은 배치의 이벤트 66개가 함께 죽는다.
    //
    // update를 여는 이유: 업로드는 성공했는데 removeUploaded() 전에 앱이 죽으면
    // 같은 eventId가 재업로드된다. 그때 문서가 이미 있어 update가 되는데,
    // 막아두면 그 사용자는 이후 업로드가 영구히 실패한다. 읽기가 막혀 있어
    // 남의 eventId(UUID)를 알아낼 방법이 없으므로 덮어쓰기 위험은 낮다.
    match /telemetry_events/{eventId} {
      allow create, update: if hasEventShape();
      allow read, delete: if false;
    }
    match /telemetry_feedback/{eventId} {
      allow create, update: if hasFeedbackShape();
      allow read, delete: if false;
    }

    // 집계 문서는 FieldValue.increment로 같은 문서를 계속 병합해서 update가 필수다.
    // 삭제만 막는다 — 통계를 통째로 날리는 것 방지.
    match /telemetry_command_stats/{docId} {
      allow create, update: if true;
      allow read, delete: if false;
    }
    match /telemetry_daily_stats/{docId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    // 고유 사용자 집계. **여기만 클라이언트 읽기를 연다.**
    // upsertUsersAndOverview()가 transaction.get()으로 "이 설치가 처음인가"를
    // 확인해야 totalUserCount를 한 번만 올릴 수 있다. 읽기를 전부 막으면
    // 트랜잭션이 실패해서 업로드 전체가 죽는다.
    //
    // 대신 get(단건)만 열고 list(질의·열거)는 막는다. 문서 ID가 installId(UUID)라서
    // **자기 UUID를 이미 아는 클라이언트만 자기 문서를 읽을 수 있고**, 남의 것을
    // 훑을 수는 없다. 이 구분이 없으면 전체 사용자 목록이 그대로 노출된다.
    match /telemetry_users/{userId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if true;
      allow delete: if false;
    }

    // 전체 누계 카운터 하나. increment만 하므로 읽기는 필요 없다
    match /telemetry_overview/{docId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    // 위에 없는 경로는 전부 차단. 새 컬렉션을 추가하면 여기 규칙도 같이 추가해야 한다
    match /{document=**} {
      allow read, write: if false;
    }

    // 익명 클라이언트가 쓰는 구조라 완전한 방어는 불가능하다.
    // 실수나 장난으로 이상한 문서가 들어오는 것만 막는 수준의 형태 검증이다.
    //
    // **검증을 추가할 때는 실제 업로드 코드(TelemetryUploader.kt)의 map을 먼저 볼 것.**
    // 코드에 없는 필드를 요구하면 그 컬렉션만이 아니라 배치 전체가 죽는다.

    // toFirestoreMap() 기준
    function hasEventShape() {
      return request.resource.data.keys().hasAll(['eventId', 'eventName', 'timestamp'])
          && request.resource.data.eventName is string
          && request.resource.data.eventName.size() < 64;
    }

    // toFeedbackMap() 기준 — eventName이 없다
    function hasFeedbackShape() {
      return request.resource.data.keys().hasAll(['eventId', 'timestamp'])
          && request.resource.data.get('message', '') is string;
    }
  }
}
